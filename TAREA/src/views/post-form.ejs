<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Social Media - <%= post ? 'Editar' : 'Crear' %> Post</title>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
  <style>
    body { background-color: #f4f7f6; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
    .card { border-radius: 12px; }
    .btn, .btn-large { border-radius: 8px; }
    .input-field input:focus + label, .input-field textarea:focus + label { color: #303f9f !important; }
    .input-field input:focus, .input-field textarea:focus { border-bottom: 1px solid #303f9f !important; box-shadow: 0 1px 0 0 #303f9f !important; }
  </style>
</head>
<body>
  <nav>
    <div class="nav-wrapper indigo darken-2">
      <a href="/" class="brand-logo center"><i class="material-icons">camera</i>Social Media</a>
    </div>
  </nav>

  <div class="container" style="margin-top: 40px; max-width: 700px;">
    <div class="card hoverable z-depth-3" style="padding: 30px;">
        <h4 class="center-align indigo-text text-darken-3" style="font-weight: bold; margin-bottom: 30px;">
            <i class="material-icons medium vertical-align-middle"><%= post ? 'edit' : 'create' %></i>
            <%= post ? 'Editar Publicación' : 'Crear Nueva Publicación' %>
        </h4>
        
        <form action="<%= post ? '/posts/update/' + post._id : '/posts/new' %>" method="POST">
            <div class="row">
                <% if (!post) { %>
                <div class="input-field col s12">
                    <i class="material-icons prefix indigo-text">account_circle</i>
                    <select name="user" required>
                        <option value="" disabled selected>Selecciona al autor genial</option>
                        <% users.forEach(u => { %>
                            <option value="<%= u._id %>"><%= u.name %> <%= u.lastName %></option>
                        <% }) %>
                    </select>
                    <label>Autor del Post</label>
                </div>
                <% } %>

                <div class="input-field col s12">
                    <i class="material-icons prefix indigo-text">title</i>
                    <input type="text" name="title" id="title" value="<%= post ? post.title : '' %>" required minlength="5" maxlength="30">
                    <label for="title">Título (5-30 caracteres)</label>
                </div>

                <div class="input-field col s12">
                    <i class="material-icons prefix indigo-text">short_text</i>
                    <textarea name="content" id="content" class="materialize-textarea" required minlength="10"><%= post ? post.content : '' %></textarea>
                    <label for="content">Contenido (mínimo 10 caracteres)</label>
                </div>

                <div class="input-field col s12">
                    <i class="material-icons prefix indigo-text">image</i>
                    <input type="url" name="imageUrl" id="imageUrl" value="<%= post ? post.imageUrl : '' %>">
                    <label for="imageUrl">URL de Imagen (Opcional pero recomendada)</label>
                </div>

                <div class="input-field col s12">
                    <i class="material-icons prefix indigo-text">tag</i>
                    <input type="text" name="hashtags" id="hashtags" value="<%= post && post.hashtags ? post.hashtags.join(', ') : '' %>">
                    <label for="hashtags">Hashtags (Ej: node, express, mongodb)</label>
                    <span class="helper-text">Separados por coma</span>
                </div>

                <div class="col s12 center-align" style="margin-top: 20px;">
                    <a href="/posts" class="btn-large grey lighten-2 grey-text text-darken-3 waves-effect" style="margin-right: 15px;">Cancelar</a>
                    <button type="submit" class="btn-large indigo darken-2 waves-effect waves-light">
                        Guardar Post <i class="material-icons right">send</i>
                    </button>
                </div>
            </div>
        </form>
    </div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
        var elems = document.querySelectorAll('select');
        M.FormSelect.init(elems);
    });
  </script>
</body>
</html>
