<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Social Media - Posts</title>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
  <style>
    body { background-color: #f4f7f6; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
    /* Flexbox para emparejar las tarjetas */
    .row { display: flex; flex-wrap: wrap; }
    .col.s12.m6.l4 { display: flex; }
    .card { display: flex; flex-direction: column; width: 100%; border-radius: 12px; overflow: hidden; margin: 0.5rem 0 1rem 0; }
    .card-content { flex-grow: 1; }
    .btn, .btn-floating { border-radius: 8px; }
  </style>
</head>
<body>
  <nav>
    <div class="nav-wrapper indigo darken-2 shadow-2">
      <a href="/" class="brand-logo center"><i class="material-icons">camera</i>Social Media</a>
    </div>
  </nav>

  <div class="container" style="margin-top: 30px;">
    <h4 class="center-align indigo-text text-darken-3" style="font-weight: bold;">Explorar Publicaciones</h4>
    <div class="center-align" style="margin-bottom: 30px;">
        <a href="/posts/new" class="btn-large green accent-4 waves-effect waves-light hoverable" style="border-radius: 20px;"><i class="material-icons left">add_circle</i>Crear Nuevo Post</a>
    </div>

    <div class="row">
      <% if (posts.length === 0) { %>
        <div class="col s12 center-align" style="margin-top: 40px;">
            <i class="material-icons large grey-text text-lighten-2">sentiment_dissatisfied</i>
            <h5 class="grey-text">No hay publicaciones aún. ¡Anímate a ser el primero!</h5>
        </div>
      <% } %>
      <% posts.forEach(post => { %>
      <div class="col s12 m6 l4">
        <div class="card hoverable z-depth-2">
          <div class="card-image">
            <img src="<%= post.imageUrl || 'https://images.unsplash.com/photo-1498050108023-c5249f4df085?auto=format&fit=crop&w=600&q=80' %>" alt="Imagen del post" style="height: 220px; object-fit: cover;">
          </div>
          <div class="card-content">
            <span class="card-title truncate" title="<%= post.title %>" style="font-weight: 600;"><%= post.title %></span>
            <p class="truncate grey-text text-darken-2" title="<%= post.content %>"><%= post.content %></p>
            <div style="margin-top: 15px;">
              <% if (post.hashtags && post.hashtags.length > 0) { %>
                <% post.hashtags.forEach(tag => { %>
                  <span class="chip indigo lighten-5 indigo-text text-darken-2" style="font-weight: 500;">#<%= tag %></span>
                <% }) %>
              <% } else { %>
                <span class="grey-text"><small>Sin etiquetas</small></span>
              <% } %>
            </div>
          </div>
          <div class="card-action grey lighten-5">
            <div class="right" style="display: flex; gap: 8px;">
              <a href="/posts/edit/<%= post._id %>" class="btn-floating btn-small blue waves-effect waves-light"><i class="material-icons">edit</i></a>
              <form action="/posts/delete/<%= post._id %>" method="POST" style="margin: 0;" onsubmit="return confirm('¿Estás seguro de eliminar esta publicación?');">
                <button type="submit" class="btn-floating btn-small red waves-effect waves-light"><i class="material-icons">delete</i></button>
              </form>
            </div>
            <span class="grey-text text-darken-2"><i class="material-icons tiny left">person</i><b><%= post.user ? post.user.name + ' ' + post.user.lastName : 'Desconocido' %></b></span>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
</body>
</html>
